        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "bot_name",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(dofus_bot_kamas, bot_name)" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(dofus_bot_kamas, server)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "server",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(dofus_bot_kamas, server)" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
